<Window x:Class="NpcNotebook.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        ResizeMode="NoResize"
        Style="{StaticResource FantasyWindow}">
    <Border Style="{StaticResource FantasyPanel}" Margin="12">
        <StackPanel MinWidth="320">
            <TextBlock x:Name="PromptText" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="InputBox" AcceptsReturn="False" MinWidth="300"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Style="{StaticResource FantasyCompactButton}" IsCancel="True"
                        Click="Cancel_Click"/>
                <Button Content="OK" Style="{StaticResource FantasyCompactButton}" IsDefault="True"
                        Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
