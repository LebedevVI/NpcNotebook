<Window x:Class="NpcNotebook.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:NpcNotebook.Converters"
        xmlns:models="clr-namespace:NpcNotebook.Models"
        Title="{Binding WindowTitle}"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource FantasyWindow}">
    <Window.Resources>
        <conv:PortraitConverter x:Key="PortraitConverter"/>
        <conv:NpcSelectionBorderConverter x:Key="NpcSelectionBorderConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <Style x:Key="SingleLineTextBox" TargetType="TextBox" BasedOn="{StaticResource FantasyTextBox}">
            <Setter Property="AcceptsReturn" Value="False"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
        </Style>

        <Style x:Key="NpcCardBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupHeaderBorder" TargetType="Border">
            <Setter Property="Background" Value="#66C9A86C"/>
            <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="PortraitPlaceholder" TargetType="Border">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#55E8D4A8"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource FantasyCompactPanel}" Margin="4,4,4,2" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Открыть" Style="{StaticResource FantasyCompactButton}"
                            ToolTip="Открыть блокнот (.npcbook)" Click="Open_Click"/>
                    <Button Content="Сохранить" Style="{StaticResource FantasyCompactButton}"
                            ToolTip="Сохранить блокнот — выбрать файл (.npcbook)" Click="Save_Click"/>
                </StackPanel>

                <TextBox Grid.Column="1" Margin="12,0"
                         Style="{StaticResource SingleLineTextBox}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Поиск по имени, расе, роду деятельности"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="+ Группа" Style="{StaticResource FantasyCompactButton}"
                            Command="{Binding CreateGroupCommand}"
                            ToolTip="Создать новую группу"/>
                    <Button Content="+ Персонаж" Style="{StaticResource FantasyCompactButton}"
                            Command="{Binding CreateCharacterCommand}"
                            ToolTip="Создать нового NPC"/>
                    <Button Content="?" Style="{StaticResource FantasyCompactButton}" Width="32" Padding="0"
                            ToolTip="Справка" Click="Help_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource FantasyCompactPanel}" Margin="4,2,4,4" Padding="8,6">
            <TextBlock Text="{Binding StatusText}" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- Список групп -->
            <Border Grid.Column="0" Style="{StaticResource FantasyPanel}" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Персонажи" FontWeight="Bold" FontSize="16"
                               Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding GroupSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <Border Style="{StaticResource GroupHeaderBorder}"
                                                AllowDrop="True"
                                                Drop="GroupHeader_Drop"
                                                DragOver="GroupHeader_DragOver"
                                                Tag="{Binding}"
                                                MouseRightButtonUp="GroupHeader_RightClick">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"/>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding Characters}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:NpcCharacter}">
                                                    <Border Style="{StaticResource NpcCardBorder}"
                                                            PreviewMouseLeftButtonDown="NpcCard_Click"
                                                            PreviewMouseMove="NpcCard_PreviewMouseMove"
                                                            MouseRightButtonUp="NpcCard_RightClick">
                                                        <Border.Background>
                                                            <MultiBinding Converter="{StaticResource NpcSelectionBorderConverter}">
                                                                <Binding/>
                                                                <Binding Path="DataContext.SelectedCharacter"
                                                                         RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </Border.Background>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,8,0">
                                                                <Border Style="{StaticResource PortraitPlaceholder}">
                                                                    <TextBlock Text="?" FontSize="20" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{StaticResource LeatherBrush}"/>
                                                                </Border>
                                                                <Image Source="{Binding Converter={StaticResource PortraitConverter}}"
                                                                       Stretch="UniformToFill"
                                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                                    <Image.Clip>
                                                                        <RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,48,48"/>
                                                                    </Image.Clip>
                                                                </Image>
                                                            </Grid>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True"
                          Background="Transparent"/>

            <!-- Карточка персонажа -->
            <Border Grid.Column="2" Style="{StaticResource FantasyPanel}" Padding="8">
                <Grid>
                    <Grid Visibility="{Binding SelectedCharacter, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="160"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="1.2*" MinHeight="180"/>
                        </Grid.RowDefinitions>

                        <!-- Верх: поля и отношения (с прокруткой) -->
                        <ScrollViewer Grid.Row="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,4,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <Border Width="120" Height="120" CornerRadius="6"
                                                BorderBrush="{StaticResource LeatherBrush}" BorderThickness="2"
                                                Background="#55E8D4A8" Cursor="Hand"
                                                MouseLeftButtonUp="Portrait_Click">
                                            <Grid>
                                                <TextBlock Text="?" FontSize="36" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{StaticResource LeatherBrush}"/>
                                                <Image Source="{Binding SelectedCharacter, Converter={StaticResource PortraitConverter}}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Clip>
                                                        <RectangleGeometry RadiusX="4" RadiusY="4" Rect="0,0,120,120"/>
                                                    </Image.Clip>
                                                </Image>
                                            </Grid>
                                        </Border>
                                        <Button Content="Загрузить портрет" Style="{StaticResource FantasyCompactButton}"
                                                Margin="0,8,0,0" Command="{Binding ChoosePortraitCommand}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Имя" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBox Style="{StaticResource SingleLineTextBox}"
                                                 Text="{Binding SelectedCharacter.Name, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Раса" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource SingleLineTextBox}"
                                                         Text="{Binding SelectedCharacter.Race, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Возраст" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBox Style="{StaticResource SingleLineTextBox}"
                                                         Text="{Binding SelectedCharacter.Age, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Род деятельности" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                        <TextBox Style="{StaticResource SingleLineTextBox}"
                                                 Text="{Binding SelectedCharacter.Occupation, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Text="Характер" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                        <TextBox MinHeight="72" MaxHeight="160"
                                                 Text="{Binding SelectedCharacter.Personality, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Style="{StaticResource FantasyCompactPanel}" Margin="0,0,0,8" Padding="8">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left" Text="Отношения" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button DockPanel.Dock="Right" Content="+ Добавить"
                                                Style="{StaticResource FantasyCompactButton}"
                                                Command="{Binding AddRelationshipCommand}"/>
                                    </DockPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding SelectedCharacter.Relationships}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:NpcRelationship}">
                                            <Border BorderBrush="{StaticResource LeatherBrush}" BorderThickness="1"
                                                    CornerRadius="3" Padding="6" Margin="0,0,0,4"
                                                    Background="#33E8D4A8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180" MinWidth="120"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0"
                                                              ItemsSource="{Binding DataContext.RelationshipTargets, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValue="{Binding TargetNpcId}"
                                                              SelectedValuePath="Id"
                                                              DisplayMemberPath="Name"/>
                                                    <TextBox Grid.Column="2" Style="{StaticResource SingleLineTextBox}"
                                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="Описание отношения"/>
                                                    <Button Grid.Column="3" Content="×" Width="28" Padding="0"
                                                            Style="{StaticResource FantasyCompactButton}"
                                                            Command="{Binding DataContext.RemoveRelationshipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="Удалить отношение"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter Grid.Row="1" Height="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ShowsPreview="True"
                                      Background="Transparent"/>

                        <!-- Низ: диалоги (масштабируемая область) -->
                        <DockPanel Grid.Row="2" LastChildFill="True">
                            <Border DockPanel.Dock="Top" Style="{StaticResource FantasyCompactPanel}"
                                    Margin="0,0,0,4" Padding="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Диалоги и реплики" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Button Content="+ Вкладка" Style="{StaticResource FantasyCompactButton}"
                                            Command="{Binding AddDialogTabCommand}"/>
                                    <Button Content="Переименовать" Style="{StaticResource FantasyCompactButton}"
                                            Command="{Binding RenameDialogTabCommand}"
                                            CommandParameter="{Binding SelectedDialogTab}"/>
                                    <Button Content="Удалить" Style="{StaticResource FantasyCompactButton}"
                                            Command="{Binding RemoveDialogTabCommand}"
                                            CommandParameter="{Binding SelectedDialogTab}"/>
                                </StackPanel>
                            </Border>

                            <Grid>
                                <Border BorderBrush="{StaticResource LeatherBrush}"
                                        BorderThickness="2"
                                        CornerRadius="3"
                                        Background="{StaticResource InputParchmentBrush}"
                                        Visibility="{Binding HasDialogTabs, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="Нажмите «+ Вкладка», чтобы добавить реплики и диалоги"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Opacity="0.65"
                                               FontStyle="Italic"
                                               Margin="16"/>
                                </Border>

                                <TabControl Style="{StaticResource FantasyTabControl}"
                                            ItemContainerStyle="{StaticResource FantasyTabItem}"
                                            ItemsSource="{Binding SelectedCharacter.DialogTabs}"
                                            SelectedItem="{Binding SelectedDialogTab}"
                                            Visibility="{Binding HasDialogTabs, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TabControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:NpcDialogTab}">
                                            <TextBlock Text="{Binding Title}" MouseLeftButtonDown="DialogTabHeader_Click"/>
                                        </DataTemplate>
                                    </TabControl.ItemTemplate>
                                    <TabControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type models:NpcDialogTab}">
                                            <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     BorderThickness="0"
                                                     Background="Transparent"/>
                                        </DataTemplate>
                                    </TabControl.ContentTemplate>
                                </TabControl>
                            </Grid>
                        </DockPanel>
                    </Grid>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedCharacter, Converter={StaticResource InverseNullToVisibilityConverter}}">
                        <TextBlock Text="Выберите персонажа слева" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Opacity="0.7"/>
                        <TextBlock Text="или создайте нового кнопкой «+ Персонаж»"
                                   HorizontalAlignment="Center" Opacity="0.55" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
