<Window x:Class="NpcNotebook.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Справка"
        Width="620" Height="720"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource FantasyWindow}">
    <Border Style="{StaticResource FantasyPanel}" Margin="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="TitleText" Style="{StaticResource FantasyTitle}"
                       FontSize="20" Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,0,8,0">
                <StackPanel x:Name="SectionsPanel"/>
            </ScrollViewer>

            <Button Grid.Row="2" Content="Понятно, закрыть" Style="{StaticResource FantasyButton}"
                    HorizontalAlignment="Center" Margin="0,16,0,0"
                    Padding="24,8" Click="Close_Click" IsDefault="True"/>
        </Grid>
    </Border>
</Window>
