<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ParchmentLight">#F4E8C8</Color>
    <Color x:Key="ParchmentMid">#E8D4A8</Color>
    <Color x:Key="ParchmentDark">#C9A86C</Color>
    <Color x:Key="InkBrown">#3D2914</Color>
    <Color x:Key="InkGold">#8B6914</Color>
    <Color x:Key="LeatherBrown">#5C3D1E</Color>
    <Color x:Key="BloodRed">#8B2500</Color>

    <SolidColorBrush x:Key="ParchmentBrush" Color="{StaticResource ParchmentLight}"/>
    <SolidColorBrush x:Key="ParchmentMidBrush" Color="{StaticResource ParchmentMid}"/>
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkBrown}"/>
    <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource InkGold}"/>
    <SolidColorBrush x:Key="LeatherBrush" Color="{StaticResource LeatherBrown}"/>

    <LinearGradientBrush x:Key="ScrollBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FAF0D0" Offset="0"/>
        <GradientStop Color="#E5D4A0" Offset="0.5"/>
        <GradientStop Color="#D4BC82" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LeatherButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#7A5230" Offset="0"/>
        <GradientStop Color="#5C3D1E" Offset="0.5"/>
        <GradientStop Color="#4A3018" Offset="1"/>
    </LinearGradientBrush>

    <FontFamily x:Key="FantasyTitleFont">Palatino Linotype, Georgia, Times New Roman</FontFamily>
    <FontFamily x:Key="FantasyBodyFont">Georgia, Palatino Linotype, Times New Roman</FontFamily>

    <Style x:Key="FantasyWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource ScrollBackgroundBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
    </Style>

    <Style x:Key="FantasyPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ScrollBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="3" Opacity="0.4" Color="#3D2914"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FantasyTitleFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FantasyButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource LeatherButtonBrush}"/>
        <Setter Property="Foreground" Value="#FAF0D0"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyTitleFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="BorderBrush" Value="#3D2914"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#9A6840" Offset="0"/>
                                        <GradientStop Color="#6B4528" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyToolButton" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
        <Setter Property="Background" Value="{StaticResource ParchmentMidBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#C9A86C"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#8B2500"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#F0E0B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyCompactButton" TargetType="Button" BasedOn="{StaticResource FantasyButton}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style x:Key="FantasyCompactToolButton" TargetType="ToggleButton" BasedOn="{StaticResource FantasyToolButton}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Margin" Value="1"/>
    </Style>

    <Style x:Key="FantasyCompactPanel" TargetType="Border" BasedOn="{StaticResource FantasyPanel}">
        <Setter Property="Padding" Value="6"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Margin" Value="4"/>
    </Style>

    <LinearGradientBrush x:Key="InputParchmentBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F0E4C0" Offset="0"/>
        <GradientStop Color="#E8D4A8" Offset="0.55"/>
        <GradientStop Color="#D9C088" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#8B6914"/>
    <SolidColorBrush x:Key="SelectionParchmentBrush" Color="#C9A86C"/>

    <Style x:Key="FantasyTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="CaretBrush" Value="{StaticResource InkBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource SelectionParchmentBrush}"/>
        <Setter Property="SelectionTextBrush" Value="{StaticResource InkBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{StaticResource InputParchmentBrush}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ScrollViewer x:Name="PART_ContentHost"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                        VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                        Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyListBox" TargetType="ListBox">
        <Setter Property="Background" Value="#55E8D4A8"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="FantasyListBoxItem" TargetType="ListBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#66E8D4A8"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#998B6914"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#AAC9A86C"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="Selector.IsSelectionActive" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#99C9A86C"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="2">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#66E8D4A8"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#998B6914"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#88C9A86C"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#AAC9A86C"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyComboBoxToggleButton" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="arrowBorder"
                            Background="{StaticResource LeatherButtonBrush}"
                            BorderBrush="{StaticResource LeatherBrush}"
                            BorderThickness="1,0,0,0"
                            CornerRadius="0,2,2,0">
                        <Path x:Name="arrow"
                              Data="M 0,0 L 4,4 L 8,0 Z"
                              Fill="#FAF0D0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="0,1,0,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="arrowBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#9A6840" Offset="0"/>
                                        <GradientStop Color="#6B4528" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="arrowBorder" Property="Background" Value="#8B6914"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyComboBox" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource FantasyComboBoxItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="border"
                                Grid.ColumnSpan="2"
                                Background="{StaticResource InputParchmentBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>

                        <ContentPresenter Grid.Column="0"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          IsHitTestVisible="False"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>

                        <ToggleButton Grid.Column="1"
                                      Style="{StaticResource FantasyComboBoxToggleButton}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="dropDownBorder"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource ScrollBackgroundBrush}"
                                    BorderBrush="{StaticResource LeatherBrush}"
                                    BorderThickness="2"
                                    CornerRadius="3"
                                    Margin="0,2,0,0"
                                    Padding="2">
                                <ScrollViewer SnapsToDevicePixels="True"
                                              HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource InputFocusBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <LinearGradientBrush x:Key="ScrollTrackBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E0CC98" Offset="0"/>
        <GradientStop Color="#C9A86C" Offset="0.5"/>
        <GradientStop Color="#B89860" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ScrollThumbBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FAF0D0" Offset="0"/>
        <GradientStop Color="#E8D4A8" Offset="0.5"/>
        <GradientStop Color="#D4BC82" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ScrollThumbHoverBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFF8E8" Offset="0"/>
        <GradientStop Color="#E5C890" Offset="1"/>
    </LinearGradientBrush>

    <!-- Ползунок: «жердь» свитка -->
    <Style x:Key="FantasyScrollThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Margin="3,2"
                            CornerRadius="5"
                            BorderBrush="{StaticResource LeatherBrush}"
                            BorderThickness="1"
                            Background="{StaticResource ScrollThumbBrush}">
                        <Border Margin="4,0" BorderBrush="#8B6914" BorderThickness="0,0,0,0" Opacity="0.35">
                            <Rectangle Width="2" HorizontalAlignment="Center" RadiusX="1" RadiusY="1"
                                       Fill="{StaticResource LeatherBrush}" Opacity="0.5"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollThumbHoverBrush}"/>
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#8B6914"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#C9A86C"/>
                            <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#8B2500"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Вертикальная полоса прокрутки в стиле переплёта свитка -->
    <Style x:Key="FantasyScrollBar" TargetType="ScrollBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Width="{TemplateBinding Width}">
                        <Border Background="{StaticResource ScrollTrackBrush}"
                                BorderBrush="{StaticResource LeatherBrush}"
                                BorderThickness="1,1,1,1"
                                CornerRadius="4"
                                Margin="0,1"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="0"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand" Focusable="False">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="0"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource FantasyScrollThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Height="{TemplateBinding Height}">
                                <Border Background="{StaticResource ScrollTrackBrush}"
                                        BorderBrush="{StaticResource LeatherBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="1,0"/>
                                <Track x:Name="PART_Track" Focusable="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineLeftCommand" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent" Width="0"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineRightCommand" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent" Width="0"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource FantasyScrollThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Глобальные стили по умолчанию -->
    <Style TargetType="TextBox" BasedOn="{StaticResource FantasyTextBox}"/>
    <Style TargetType="ComboBox" BasedOn="{StaticResource FantasyComboBox}"/>
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource FantasyComboBoxItem}"/>
    <Style TargetType="ScrollBar" BasedOn="{StaticResource FantasyScrollBar}"/>
    <Style TargetType="ListBox" BasedOn="{StaticResource FantasyListBox}"/>
    <Style TargetType="ListBoxItem" BasedOn="{StaticResource FantasyListBoxItem}"/>

    <Style x:Key="FantasyTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource InputParchmentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0"
                                Background="{StaticResource ParchmentMidBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                CornerRadius="3,3,0,0"
                                Padding="4,4,4,0">
                            <TabPanel IsItemsHost="True"/>
                        </Border>
                        <Border Grid.Row="1"
                                Background="{StaticResource InputParchmentBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="0,0,3,3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="SelectedContent"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasyTabItem" TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource FantasyBodyFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="tabBorder"
                            Background="{StaticResource ParchmentMidBrush}"
                            BorderBrush="{StaticResource LeatherBrush}"
                            BorderThickness="1"
                            CornerRadius="3,3,0,0"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="{StaticResource InputParchmentBrush}"/>
                            <Setter TargetName="tabBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            <Setter TargetName="tabBorder" Property="BorderThickness" Value="2,2,2,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tabBorder" Property="Background" Value="#F0E0B8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FantasySlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="Background" Value="{StaticResource ParchmentMidBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LeatherBrush}"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="6"
                                Margin="6,0"
                                Background="{StaticResource InputParchmentBrush}"
                                BorderBrush="{StaticResource LeatherBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="16" Height="22" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource LeatherButtonBrush}"
                                                    BorderBrush="{StaticResource LeatherBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
